{
  "name": "bug-hunter",
  "displayName": "Bug Hunter",
  "description": "Gamified code analysis — fight bugs in a turn-based RPG inside VS Code",
  "version": "0.0.4",
  "publisher": "bughunter",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bughunter/bughunter"
  },
  "bugs": {
    "url": "https://github.com/bughunter/bughunter/issues"
  },
  "homepage": "https://github.com/bughunter/bughunter#readme",
  "keywords": [
    "gamification",
    "code-analysis",
    "linter",
    "bugs",
    "rpg",
    "developer-tools"
  ],
  "categories": [
    "Linters",
    "Education",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bug-hunter",
          "title": "Bug Hunter",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "bug-hunter": [
        {
          "type": "webview",
          "id": "bugHunter.sidebar",
          "name": "Bug Hunter"
        }
      ]
    },
    "commands": [
      {
        "command": "bugHunter.refresh",
        "title": "Bug Hunter: Refresh Webview",
        "icon": "$(refresh)"
      },
      {
        "command": "bugHunter.focus",
        "title": "Bug Hunter: Focus Sidebar"
      },
      {
        "command": "bugHunter.rescanWorkspace",
        "title": "Bug Hunter: Rescan workspace"
      }
    ],
    "keybindings": [
      {
        "command": "bugHunter.focus",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "bugHunter.refresh",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r",
        "when": "view.bugHunter.sidebar.visible"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "bugHunter.refresh",
          "when": "view == bugHunter.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Bug Hunter",
      "properties": {
        "bugHunter.fileHooksEnabled": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, debounced file open/change events emit FILE_ANALYZED on the extension event bus (for future analyzers)."
        },
        "bugHunter.fileHookDebounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 10000,
          "description": "Debounce delay in milliseconds for file change and open events."
        },
        "bugHunter.workspaceScanEnabled": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, scan JS/TS files across the workspace (on startup, save, and rescan command) and aggregate bugs. When disabled, only the active editor buffer is analyzed via file hooks."
        },
        "bugHunter.workspaceScanInclude": {
          "type": "string",
          "default": "**/*.{js,cjs,mjs,jsx,ts,tsx}",
          "description": "Glob for workspace.findFiles (relative to the workspace folder)."
        },
        "bugHunter.workspaceScanExclude": {
          "type": "string",
          "default": "",
          "description": "Extra comma-separated path fragments to skip (substring match, lowercased), in addition to node_modules, dist, .git, etc."
        },
        "bugHunter.workspaceMaxFileSizeBytes": {
          "type": "number",
          "default": 524288,
          "minimum": 1024,
          "maximum": 10485760,
          "description": "Skip reading/analyzing files larger than this many bytes."
        },
        "bugHunter.workspaceScanConcurrency": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 32,
          "description": "Maximum concurrent file reads/analyses during a workspace scan."
        },
        "bugHunter.workspaceMaxUiIssues": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 10000,
          "description": "Cap issues sent to the sidebar (severity-sorted) for very large repos."
        },
        "bugHunter.workspaceLiveBuffers": {
          "type": "boolean",
          "default": true,
          "description": "When workspace scan is on, also debounce-analysis open buffers on edit/tab change. Disable to only use disk scans (save + full rescan)."
        },
        "bugHunter.sidebar.dashboard": {
          "type": "boolean",
          "default": true,
          "description": "Show the Dashboard section (level, XP, session stats)."
        },
        "bugHunter.sidebar.store": {
          "type": "boolean",
          "default": true,
          "description": "Show the Boogles store (cosmetics)."
        },
        "bugHunter.sidebar.bugArena": {
          "type": "boolean",
          "default": true,
          "description": "Show the active bugs / arena list."
        },
        "bugHunter.sidebar.defeatedArchive": {
          "type": "boolean",
          "default": true,
          "description": "Show the defeated bugs archive."
        },
        "bugHunter.sidebar.activityLog": {
          "type": "boolean",
          "default": true,
          "description": "Show the activity log."
        },
        "bugHunter.sidebar.issues": {
          "type": "boolean",
          "default": true,
          "description": "Show the raw issues panel."
        },
        "bugHunter.sidebar.headerProfile": {
          "type": "boolean",
          "default": true,
          "description": "Show the avatar and border in the header (title and status stay visible)."
        },
        "bugHunter.sidebar.companion": {
          "type": "string",
          "default": "always",
          "enum": [
            "none",
            "always",
            "equippedOnly"
          ],
          "enumDescriptions": [
            "Never show the companion panel.",
            "Always show the companion area (including the prompt when no pet is equipped).",
            "Only show the companion area when a pet is equipped."
          ],
          "description": "Companion pet panel visibility."
        }
      }
    }
  },
  "scripts": {
    "build": "node ./scripts/esbuild.mjs && node ./scripts/copy-webview.mjs",
    "build:production": "node ./scripts/esbuild.mjs --production && node ./scripts/copy-webview.mjs",
    "watch": "node ./scripts/esbuild.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "vscode:prepublish": "npm run build:production",
    "vsix": "node ./scripts/package-vsix.mjs",
    "clean": "rm -rf out media/webview",
    "test": "vitest run"
  },
  "dependencies": {
    "@bughunter/ai": "*",
    "@bughunter/analyzers": "*",
    "@bughunter/game-engine": "*",
    "@bughunter/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.12",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
